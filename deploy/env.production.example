# ╔══════════════════════════════════════════════════════════════╗
# ║   .env — AutoWorks Bolivia — PRODUCCIÓN VPS                  ║
# ║   Copia este archivo al servidor como: backend/.env          ║
# ║   ⚠️  NUNCA subas este archivo al repositorio Git            ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Base de Datos SQL Server ────────────────────────────────────────
# Opción A: SQL Server local en el VPS
DB_SERVER=localhost
DB_NAME=taller4
DB_USER=valeria
DB_PASSWORD=123456789
DB_DRIVER=ODBC Driver 17 for SQL Server

# Opción B: SQL Server remoto (descomenta si aplica)
# DB_SERVER=tu-servidor-remoto.database.windows.net
# DB_NAME=taller4
# DB_USER=tu_usuario
# DB_PASSWORD=tu_password_seguro

# ── API ─────────────────────────────────────────────────────────────
# URL base pública de la API (sin /api al final)
API_BASE_URL=http://185.214.134.23:8000

# Puerto donde escucha Uvicorn (leído por el servicio systemd)
API_PORT=8000

# ── JWT ─────────────────────────────────────────────────────────────
# ⚠️  Cambia SECRET_KEY por una cadena aleatoria y segura
# Genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_64_CARACTERES_MINIMO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Servicios de IA ─────────────────────────────────────────────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=
